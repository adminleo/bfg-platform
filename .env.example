# BFG Platform — Environment Variables
# Copy to .env and fill in your values

# Anthropic API (required for AI features)
ANTHROPIC_API_KEY=

# Security (CHANGE IN PRODUCTION)
SECRET_KEY=dev-secret-key-change-in-production
TOKEN_HMAC_SECRET=token-hmac-secret-change-in-production

# Database (default for docker compose)
DATABASE_URL=postgresql+asyncpg://bfg:bfg_dev_2024@db:5432/bfg

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# Environment
ENVIRONMENT=development

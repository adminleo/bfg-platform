# ── API Keys ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Security (REQUIRED — app will not start without these) ──
SECRET_KEY=          # Generate with: openssl rand -hex 32
TOKEN_HMAC_SECRET=   # Generate with: openssl rand -hex 32

# ── Database (REQUIRED) ──
POSTGRES_USER=gr8hub
POSTGRES_PASSWORD=   # Generate with: openssl rand -hex 16
POSTGRES_DB=gr8hub
DATABASE_URL=postgresql+asyncpg://gr8hub:YOUR_PASSWORD@db:5432/gr8hub  # pragma: allowlist secret

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Qdrant ──
QDRANT_URL=http://qdrant:6333

# ── CORS (comma-separated origins for production) ──
# ALLOWED_ORIGINS=https://app.gr8hub.com,https://gr8hub.com
